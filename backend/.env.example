# Copy relevant values into real environment variables for your deployment
# platform (Render/Railway/etc). FastAPI does not auto-load this file — these
# are read via os.environ.get(...) with safe local-dev defaults, so this file
# is informational/optional for local development.

# Secret used to sign JWT session tokens. MUST be a random value in production.
SECRET_KEY=change-me-to-a-long-random-string

# Comma-separated list of allowed frontend origins for CORS.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# SQLAlchemy database URL. Defaults to a local SQLite file at the repo root.
DATABASE_URL=sqlite:///./signal.db

# Public URL of this backend, used to build links to uploaded files.
PUBLIC_BASE_URL=http://localhost:8000
